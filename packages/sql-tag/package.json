{
  "name": "@slonik/sql-tag",
  "version": "48.13.2",
  "description": "A Node.js PostgreSQL client with strict types, detailed logging and assertions.",
  "keywords": [
    "postgresql",
    "promise",
    "types"
  ],
  "license": "BSD-3-Clause",
  "author": {
    "name": "Gajus Kuizinas",
    "email": "gajus@gajus.com",
    "url": "http://gajus.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gajus/slonik"
  },
  "files": [
    "./src",
    "./dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -fr ./dist && tsc --project ./tsconfig.json",
    "lint": "npm run lint:cspell && npm run lint:tsc",
    "lint:cspell": "cspell . --no-progress --gitignore",
    "lint:tsc": "tsc --noEmit",
    "test": "ava --verbose --serial"
  },
  "dependencies": {
    "@slonik/errors": "^48.13.2",
    "@slonik/types": "^48.13.2",
    "roarr": "^7.21.4",
    "safe-stable-stringify": "^2.5.0",
    "serialize-error": "^12.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.0.0",
    "@types/node": "^24.10.13",
    "ava": "^6.4.1",
    "cspell": "^9.6.4",
    "tsimp": "^2.0.12",
    "typescript": "^5.9.3"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "files": [
      "src/**/*.test.ts"
    ],
    "nodeArguments": [
      "--import=tsimp"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
