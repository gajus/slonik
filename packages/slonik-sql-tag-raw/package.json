{
  "name": "slonik-sql-tag-raw",
  "version": "48.12.3",
  "description": "Logs Slonik queries.",
  "keywords": [
    "interceptor",
    "logging",
    "postgresql"
  ],
  "license": "BSD-3-Clause",
  "author": {
    "name": "Gajus Kuizinas",
    "email": "gajus@gajus.com",
    "url": "http://gajus.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gajus/slonik"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -fr ./dist && tsc",
    "lint": "tsc --noEmit",
    "test": "ava --verbose --serial"
  },
  "dependencies": {
    "@slonik/sql-tag": "^48.12.3",
    "roarr": "^7.21.4"
  },
  "devDependencies": {
    "ava": "^6.4.1",
    "slonik": "^48.12.3",
    "tsimp": "^2.0.12",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "slonik": ">=45.0.0"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "files": [
      "src/**/*.test.ts"
    ],
    "nodeArguments": [
      "--import=tsimp"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
